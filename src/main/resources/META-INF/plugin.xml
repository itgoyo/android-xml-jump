<idea-plugin>
    <id>com.itgoyo.android-xml-jump</id>
    <name>Android XML Jump</name>
    <vendor email="itgoyo@example.com">itgoyo</vendor>

    <description><![CDATA[
        Jump between Android layout XML files and the Java or Kotlin classes that reference them.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.xml</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Android XML Jump" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action
            id="AndroidXmlJump.GoToLayoutOwner"
            class="com.itgoyo.androidxmljump.GoToLayoutOwnerAction"
            text="Jump Between Layout and Owner"
            description="Open the class that references the current layout XML, or open the layout XML referenced by the current class">
            <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="meta ctrl L"/>
        </action>
    </actions>
</idea-plugin>
